From 62ae25e7e3fc2ca2d60a3584f01cabbe6353e67f Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Fri, 17 Jul 2026 09:55:20 -0700
Subject: [PATCH] continue if exist

---
 pip_pkg.sh | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/pip_pkg.sh b/pip_pkg.sh
index ff74839..01c64e8 100755
--- a/pip_pkg.sh
+++ b/pip_pkg.sh
@@ -42,8 +42,16 @@ else
   RUNFILES_DIR=bazel-bin/pip_pkg.runfiles
 fi
 
-cp -L -Rf "${RUNFILES_DIR}/tensorflow_probability" "${pip_tmp}"
-
+src="${RUNFILES_DIR}/tensorflow_probability"
+mkdir -p "${pip_tmp}/tensorflow_probability"
+# Windows: cp -L -R trips on runfiles artifact "pip_pkg" (file vs dir).
+for entry in "${src}"/*; do
+  base="$(basename "${entry}")"
+  if [[ "${base}" == "pip_pkg" ]]; then
+    continue
+  fi
+  cp -L -R "${entry}" "${pip_tmp}/tensorflow_probability/"
+done
 cd "${pip_tmp}/tensorflow_probability"
 
 echo >>tensorflow_probability/python/version.py \
-- 
2.39.5 (Apple Git-154)

